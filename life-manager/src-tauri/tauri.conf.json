{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Life Manager",
  "version": "0.3.2",
  "identifier": "com.y0zrin.lifemanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Life Manager",
        "width": 1024,
        "height": 720,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/manual.pdf"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhENDc4MzI5NTBGOTIyNDAKUldSQUl2bFFLWU5IalJoNlUvMG0vWW9KUzUyb3hHbUIxbGE1ZUNWUTB5N2gxdXdxSWFHbDdQWDUK",
      "endpoints": [
        "https://github.com/y0zrin/LifeManager/releases/latest/download/latest.json"
      ]
    }
  }
}
